<!DOCTYPE html>
<html lang="en">
<body style="font-family:Arial,Helvetica,sans-serif;color:#222;">
  <h2>AI analysis ready</h2>
  <p>Hello!</p>
  <p>The LLM analysis{% if assignment_title %} for "{{ assignment_title }}"{% endif %} is ready.</p>
  {% if model %}<p>Model: <strong>{{ model }}</strong>.</p>{% endif %}
  {% if tokens_used %}<p>Tokens used: {{ tokens_used }}.</p>{% endif %}
  {% if action_url %}
  <p><a href="{{ action_url }}">View report</a></p>
  {% endif %}
  <hr>
  <p style="color:#888;font-size:12px;">PlagLens</p>
</body>
</html>
