<!DOCTYPE html>
<html lang="en">
<body style="font-family:Arial,Helvetica,sans-serif;color:#222;">
  <h2>Submission graded</h2>
  <p>Hello!</p>
  <p>
    Your submission{% if assignment_title %} <strong>{{ assignment_title }}</strong>{% endif %}
    {% if course_name %}for <strong>{{ course_name }}</strong>{% endif %} has been graded.
  </p>
  {% if score is defined %}
  <p>Score: <strong>{{ score }}{% if max_score %} of {{ max_score }}{% endif %}</strong>.</p>
  {% endif %}
  {% if action_url %}
  <p><a href="{{ action_url }}">View submission</a></p>
  {% endif %}
  <hr>
  <p style="color:#888;font-size:12px;">PlagLens — plagiarism detection and LLM-assisted review.</p>
</body>
</html>
