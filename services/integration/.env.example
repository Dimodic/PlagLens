# =============================================================================
# integration-service — environment template
# =============================================================================
# Copy this file to `.env.local` and fill in the values. `.env.local` is
# gitignored (see root `.gitignore`: `.env.*`) and must never be committed.
#
# Order of precedence (pydantic-settings):
#   1. process env vars (e.g. set by docker-compose)
#   2. .env.local                ← secrets live here
#   3. .env                       ← shared dev defaults can live here
# Higher entries override lower ones.

# ----- service basics --------------------------------------------------------
SERVICE_NAME=integration-service
ENVIRONMENT=dev
LOG_LEVEL=INFO

# ----- database / redis / kafka (defaults are fine for docker-compose) -------
# DATABASE_URL=postgresql+asyncpg://plaglens:plaglens@postgres:5432/plaglens
# REDIS_URL=redis://redis:6379/3
# KAFKA_BOOTSTRAP_SERVERS=kafka:9092

# ----- Yandex.Contest OAuth -------------------------------------------------
# Register an OAuth app at https://oauth.yandex.ru/client/new with scopes
# `contest:manage` (required, gives read access to contests/participants/runs)
# and optionally `contest:submit`.
#
# Use Redirect URI: http://localhost:5173/auth/oauth/callback
# (or your production frontend origin)
YANDEX_CONTEST_OAUTH_CLIENT_ID=replace-me-public-client-id
YANDEX_CONTEST_OAUTH_CLIENT_SECRET=replace-me-secret-from-yandex-oauth-dashboard
YANDEX_CONTEST_OAUTH_REDIRECT_URI=http://localhost:5173/auth/oauth/callback
YANDEX_CONTEST_OAUTH_SCOPE=contest:manage

# ----- Stepik OAuth (optional) ----------------------------------------------
# STEPIK_OAUTH_CLIENT_ID=
# STEPIK_OAUTH_CLIENT_SECRET=

# ----- Telegram bot (optional) ----------------------------------------------
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_BOT_USERNAME=

# ----- Webhook shared secrets (rotate before production) --------------------
WEBHOOK_SECRET_STEPIK=stepik-shared-secret-change-me
WEBHOOK_SECRET_YANDEX_CONTEST=yc-shared-secret-change-me
WEBHOOK_SECRET_PLAGIARISM=plagiarism-shared-secret-change-me
WEBHOOK_SECRET_LLM=llm-shared-secret-change-me
