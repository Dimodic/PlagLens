# PlagLens — environment variables example.
# Copy to `.env` and fill in real values. Never commit `.env`.
#
# Usage:
#   cp .env.example .env
#   docker compose up -d

# ---------------------------------------------------------------------------
# Global
# ---------------------------------------------------------------------------
PLAGLENS_ENV=dev
LOG_LEVEL=INFO
IMAGE_TAG=dev
PUBLIC_HOSTNAME=localhost
CORS_ALLOW_ORIGINS=https://localhost,http://localhost:5173

# ---------------------------------------------------------------------------
# PostgreSQL
# ---------------------------------------------------------------------------
POSTGRES_SUPERUSER=plaglens_admin
POSTGRES_PASSWORD=replace_me_postgres_pwd
POSTGRES_PORT=5432

# ---------------------------------------------------------------------------
# Redis
# ---------------------------------------------------------------------------
REDIS_PORT=6379

# ---------------------------------------------------------------------------
# Kafka (KRaft, single-node)
# ---------------------------------------------------------------------------
KAFKA_PORT=9092
KAFKA_UI_PORT=8080

# ---------------------------------------------------------------------------
# MinIO (S3-compatible object storage)
# ---------------------------------------------------------------------------
MINIO_ROOT_USER=plaglens_minio
MINIO_ROOT_PASSWORD=replace_me_minio_pwd
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# ---------------------------------------------------------------------------
# Observability
# ---------------------------------------------------------------------------
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=replace_me_grafana_pwd

# ---------------------------------------------------------------------------
# HashiCorp Vault (dev mode)
# ---------------------------------------------------------------------------
VAULT_PORT=8200
VAULT_DEV_ROOT_TOKEN=replace_me_vault_dev_token

# ---------------------------------------------------------------------------
# Traefik (TLS edge)
# ---------------------------------------------------------------------------
TRAEFIK_DASHBOARD_PORT=8081
LETS_ENCRYPT_EMAIL=admin@plaglens.local

# ---------------------------------------------------------------------------
# Mailhog (local email testing)
# ---------------------------------------------------------------------------
MAILHOG_SMTP_PORT=1025
MAILHOG_UI_PORT=8025

# ---------------------------------------------------------------------------
# JWT (Identity service)
# ---------------------------------------------------------------------------
# Generated by `make gen-keys` into infra/secrets/ and bind-mounted into
# Identity + Gateway containers as /run/secrets/. Never commit either PEM.
JWT_ISSUER=https://plaglens.local
JWT_AUDIENCE=plaglens-api
JWT_PUBLIC_KEY_PATH=/run/secrets/jwt_public.pem
JWT_PRIVATE_KEY_PATH=/run/secrets/jwt_private.pem

# ---------------------------------------------------------------------------
# Bootstrap super admin (only used on first start)
# ---------------------------------------------------------------------------
# When the identity service starts and these vars are set, the entrypoint
# runs `python -m identity_service.bootstrap_super_admin` which creates the
# system tenant + a super_admin user if neither exists. Idempotent — once
# the row exists, subsequent starts skip it.
BOOTSTRAP_SUPER_ADMIN_EMAIL=admin@plaglens.local
BOOTSTRAP_SUPER_ADMIN_PASSWORD=changeme
BOOTSTRAP_SUPER_ADMIN_TENANT_SLUG=system
# Static token for super_admin actions during bootstrap; rotate later.
BOOTSTRAP_SUPER_ADMIN_TOKEN=

# ---------------------------------------------------------------------------
# OAuth providers (Identity)
# ---------------------------------------------------------------------------
# Comma-separated list of providers active in this deployment.
OAUTH_PROVIDERS_ENABLED=google,yandex,stepik,github
# Public base URL of the API gateway — providers redirect back here.
OAUTH_CALLBACK_BASE_URL=http://localhost:8000
# How long (seconds) Redis keeps the OAuth state + PKCE verifier.
OAUTH_STATE_TTL_SECONDS=600

# Modern names (preferred):
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
YANDEX_CLIENT_ID=
YANDEX_CLIENT_SECRET=
STEPIK_CLIENT_ID=
STEPIK_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Legacy names (kept for backwards-compatibility — fall-back if the modern
# names are unset).
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=
OAUTH_YANDEX_CLIENT_ID=
OAUTH_YANDEX_CLIENT_SECRET=
OAUTH_STEPIK_CLIENT_ID=
OAUTH_STEPIK_CLIENT_SECRET=
OAUTH_GITHUB_CLIENT_ID=
OAUTH_GITHUB_CLIENT_SECRET=

# ---------------------------------------------------------------------------
# Integration adapters
# ---------------------------------------------------------------------------
STEPIK_OAUTH_CLIENT_ID=
STEPIK_OAUTH_CLIENT_SECRET=
YANDEX_CONTEST_OAUTH_CLIENT_ID=
YANDEX_CONTEST_OAUTH_CLIENT_SECRET=
TELEGRAM_BOT_TOKEN=
WEBHOOK_HMAC_SECRET=replace_me_webhook_hmac

# ---------------------------------------------------------------------------
# Plagiarism providers
# ---------------------------------------------------------------------------
MOSS_USER_ID=
CODEQUIRY_API_KEY=

# ---------------------------------------------------------------------------
# AI Analysis (LLM providers)
# ---------------------------------------------------------------------------
# LLM defaults (override per-tenant via ProviderConfig)
LLM_DEFAULT_BASE_URL=https://openrouter.ai/api/v1
LLM_DEFAULT_MODEL=openai/gpt-4o-mini
LLM_DEFAULT_PROVIDER_NAME=openrouter

# OpenRouter app attribution (per-call HTTP-Referer / X-Title headers)
OPENROUTER_HTTP_REFERER=https://plaglens.local
OPENROUTER_X_TITLE=PlagLens

# Provider API keys (env names; values in .env.local or Vault)
OPENROUTER_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
YANDEX_GPT_API_KEY=
GIGACHAT_AUTH_KEY=

# Optional legacy / per-provider knobs
OPENAI_BASE_URL=https://api.openai.com/v1
YANDEX_GPT_FOLDER_ID=
SELF_HOSTED_LLM_BASE_URL=

# ---------------------------------------------------------------------------
# Notification (email transport)
# ---------------------------------------------------------------------------
# Transport selector — `smtp` (default for dev → Mailhog) or `mailgun` (HTTP API for prod).
EMAIL_TRANSPORT=smtp

# SMTP (Mailhog in dev; Mailgun-SMTP creds in prod)
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_USE_TLS=false
SMTP_USERNAME=
SMTP_PASSWORD=

EMAIL_FROM=noreply@plaglens.local
EMAIL_FROM_NAME=PlagLens
EMAIL_REPLY_TO=

# Mailgun (production HTTP API + bounce webhook)
MAILGUN_DOMAIN=
MAILGUN_API_KEY=
MAILGUN_WEBHOOK_SIGNING_KEY=
MAILGUN_BASE_URL=https://api.mailgun.net/v3

# Bounce policy: hard bounces before email_disabled=true.
EMAIL_HARD_BOUNCES_THRESHOLD=3

# Internal HTTP token for Identity → Notification email-direct calls.
# Leave empty to disable the auth check (dev only).
NOTIFICATION_INTERNAL_TOKEN=

# Legacy / optional (kept for back-compat, may be removed later)
EMAIL_PROVIDER=mailhog
SENDGRID_API_KEY=
