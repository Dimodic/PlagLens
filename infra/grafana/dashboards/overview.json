      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "expr": "histogram_quantile(0.95, sum by (service, le) (rate(http_request_duration_seconds_bucket[5m]))) or histogram_quantile(0.95, sum by (service, le) (rate(gateway_request_duration_seconds_bucket[5m])))",
          "legendFormat": "{{service}}"
        }
      ]
    },
