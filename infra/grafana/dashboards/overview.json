      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "expr": "sum by (service) (rate(http_requests_total{status=~\"5..\"}[5m]) or rate(gateway_requests_total{status=~\"5..\"}[5m])) / clamp_min(sum by (service) (rate(http_requests_total[5m]) or rate(gateway_requests_total[5m])), 1e-9)",
          "legendFormat": "{{service}}"
        }
