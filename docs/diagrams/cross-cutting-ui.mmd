graph TB
  AnyPage["Любой авторизованный экран"]:::page

  subgraph TopBar["Topbar (закреплён, 56px)"]
    direction LR
    Back["Назад (на детальных экранах)"]:::tab
    Title["Заголовок страницы"]:::tab
    LangSeg["EN / RU"]:::tab
    Theme["Светлая / Тёмная"]:::tab
  end

  subgraph BellHeader["Колокольчик уведомлений"]
    direction TB
    Badge["счётчик непрочитанных"]:::tab
    BellDrop[("Последние 10")]:::modal
    OpenAll["→ Все уведомления"]:::router
  end

  subgraph UserPill["User pill (внизу sidebar)"]
    direction TB
    PMenu[("Меню профиля")]:::modal
    ProfileM[("Профиль")]:::modal
    PrefsM[("Настройки интерфейса")]:::modal
    HelpM[("Подсказки и хоткеи")]:::modal
    LogoutAct[/"Выйти"/]:::pub
  end

  subgraph Search["⌘ K — глобальный поиск"]
    direction TB
    SearchBox["Поиск в sidebar"]:::tab
    SearchResults[("Результаты")]:::modal
  end

  subgraph KbdShortcuts["Горячие клавиши (везде)"]
    direction TB
    GC["g + c · Курсы"]:::kbd
    GA["g + a · Мои задания"]:::kbd
    GS["g + s · Мои посылки"]:::kbd
    GD["g + d · Отчёты"]:::kbd
    GI["g + i · Импорты / экспорты"]:::kbd
    GH["g + h · Главная"]:::kbd
    GO["g + o · Обзор админа"]:::kbd
    GU["g + u · Пользователи"]:::kbd
    GL["g + l · Журнал аудита"]:::kbd
    CMDK["⌘ K · поиск"]:::kbd
    QHelp["? · Подсказки"]:::kbd
    Esc["Esc · закрыть"]:::kbd
    UpDown["↑/↓ · следующий фрагмент в diff"]:::kbd
  end

  AnyPage --> TopBar
  AnyPage --> BellHeader
  AnyPage --> UserPill
  AnyPage --> Search
  AnyPage --> KbdShortcuts

  Theme -->|меняет тему страницы| AnyPage
  LangSeg -->|меняет язык интерфейса| AnyPage

  Badge --> BellDrop
  BellDrop -->|клик по строке| ActionURL{"переход"}:::router
  ActionURL --> SubD["Карточка посылки"]:::detail
  ActionURL --> RunD["Отчёт антиплагиата"]:::detail
  ActionURL --> AsgD["Карточка задания"]:::detail
  ActionURL --> CourseD["Карточка курса"]:::detail
  ActionURL --> BudgetD["Бюджеты AI"]:::detail
  ActionURL --> SuspD["Подозрительные посылки"]:::detail
  ActionURL --> ImpD["Карточка интеграции"]:::detail
  BellDrop --> OpenAll
  OpenAll --> NotifPage["Все уведомления"]:::detail

  PMenu --> ProfileM
  PMenu --> PrefsM
  PMenu --> HelpM
  PMenu --> LogoutAct

  ProfileM -->|сохранить| AnyPage
  PrefsM -->|сохранить| AnyPage

  SearchBox --> SearchResults
  SearchResults --> CourseD
  SearchResults --> AsgD
  SearchResults --> SubD
  SearchResults --> StudentD["Карточка пользователя"]:::detail

  GC -.-> CoursesPage["Курсы"]:::nav
  GA -.-> AsgListPage["Мои задания"]:::nav
  GS -.-> SubsPage["Мои посылки"]:::nav
  GD -.-> ReportsPage["Отчёты"]:::nav
  GI -.-> ImportsPage["Импорты / экспорты"]:::nav
  GH -.-> RoleHome["Главная по роли"]:::nav
  GO -.-> AdminOverview["Обзор админа"]:::nav
  GU -.-> UsersPage["Пользователи"]:::nav
  GL -.-> AuditPage["Журнал аудита"]:::nav
  CMDK -.-> SearchBox
  QHelp -.-> HelpM

  classDef page fill:#fffefb,stroke:#3d5b4f,stroke-width:2px,color:#1d1c1a
  classDef nav fill:#e3ebe5,stroke:#3d5b4f,stroke-width:1.5px,color:#1d1c1a
  classDef detail fill:#fffefb,stroke:#c8c1b3,stroke-width:1.2px,color:#1d1c1a
  classDef tab fill:#efece5,stroke:#c8c1b3,stroke-dasharray:3 3,color:#3d3a35
  classDef modal fill:#f3e6d0,stroke:#b07a2e,color:#1d1c1a
  classDef pub fill:#fffefb,stroke:#a8a29a,stroke-dasharray:2 2,color:#3d3a35
  classDef router fill:#f0dcd6,stroke:#9c3a3a,stroke-width:2px,color:#1d1c1a
  classDef kbd fill:#232117,stroke:#6a6557,color:#f0eadc,stroke-dasharray:2 2
