# EditorConfig — https://editorconfig.org
# PlagLens repository defaults.
root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
insert_final_newline = true
trim_trailing_whitespace = true

[*.py]
indent_size = 4
max_line_length = 100

[*.{yaml,yml}]
indent_size = 2

[*.{json,toml}]
indent_size = 2

[Makefile]
indent_style = tab

[*.{md,rst}]
trim_trailing_whitespace = false
indent_size = 2

[*.{sh,bash}]
indent_size = 2

[*.{js,ts,tsx,jsx,html,css,scss}]
indent_size = 2

[Dockerfile*]
indent_size = 2
