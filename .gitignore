# ---------------------------------------------------------------------------
# Environment / secrets
# ---------------------------------------------------------------------------
.env
.env.*
!.env.example
*.local
secrets/
# Allow the placeholder dir at infra/secrets/ to exist in the checkout
# (so docker-compose's bind-mount has something to attach to). Only the
# .gitignore + README.md inside it are committed; PEM keys etc. stay out.
!infra/secrets/
infra/secrets/*
!infra/secrets/.gitignore
!infra/secrets/README.md
credentials.json
*.key
*.pem
*.p12
*.pfx
.ssh/

# detect-secrets baseline (committed)
!.secrets.baseline

# ---------------------------------------------------------------------------
# Docker / infra
# ---------------------------------------------------------------------------
.docker/
docker-compose.override.yml
*.tar
*.tar.gz

# ---------------------------------------------------------------------------
# Logs
# ---------------------------------------------------------------------------
*.log
logs/
*.log.*

# ---------------------------------------------------------------------------
