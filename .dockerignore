# PlagLens — Docker build context exclusions.

# VCS
.git/
.gitignore
.gitattributes

# Claude Code worktrees + meta (worktrees carry their own node_modules/.venv —
# excluding keeps the build context small)
.claude/

# Node / frontend build output (backend images don't need them)
node_modules/
**/node_modules/
frontend/dist/
frontend/test-results/
frontend/playwright-report/

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
*.egg
.venv/
venv/
env/
.python-version

# Test/lint caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.tox/
.coverage
.coverage.*
htmlcov/
coverage.xml

# Build artefacts
build/
dist/

# IDE
.vscode/
.idea/
*.swp

# OS
.DS_Store
Thumbs.db

# Docs / dev meta
docs/
*.md
!README.md
LICENSE
.editorconfig
.pre-commit-config.yaml
.secrets.baseline

# CI / scripts not needed at runtime
.github/
tools/
Makefile

# Local env
.env
.env.*
!.env.example

# Logs
*.log
logs/
